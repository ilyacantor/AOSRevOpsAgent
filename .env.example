# =============================================================================
# AOS RevOps Agent — Environment Variables
# Copy to .env and fill in values. Secrets go in Render dashboard.
# =============================================================================

# --- AOS Platform Integration ---
AOS_BASE_URL=                              # Platform URL (e.g. https://autonomos-platform-1.onrender.com)
AOS_TENANT_ID=demo-tenant                  # Tenant ID
AOS_AGENT_ID=revops-dev                    # Agent ID
AOS_JWT=                                   # JWT token for platform auth (optional)

# --- Salesforce (OAuth — preferred) ---
SALESFORCE_INSTANCE_URL=                   # Salesforce instance URL
SALESFORCE_CLIENT_ID=                      # OAuth client ID
SALESFORCE_CLIENT_SECRET=                  # OAuth client secret
SALESFORCE_REFRESH_TOKEN=                  # OAuth refresh token

# --- Supabase ---
SUPABASE_URL=                              # Supabase project URL
SUPABASE_KEY=                              # Supabase anon/public key

# --- MongoDB (optional) ---
MONGODB_URI=                               # MongoDB connection string
MONGODB_DATABASE=                          # MongoDB database name

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=                         # Slack webhook for alerts

# --- Auth ---
SESSION_SECRET=                            # Session signing key

# --- Frontend flag (set in frontend/.env) ---
# VITE_USE_PLATFORM_VIEWS=false            # true = use AOS platform, false = mock data
# VITE_API_URL=http://localhost:8007       # Backend API URL
